# --- Aiven MySQL Connection Details ---
# Bạn lấy thông tin kết nối từ Aiven Console -> Connection information
DB_URL=jdbc:mysql://HOST:PORT/DATABASE?sslMode=REQUIRED&serverTimezone=UTC
DB_USER=avnadmin
DB_PASS=YOUR_AIVEN_PASSWORD

# --- Gemini API Key ---
# Nhận key tại: https://aistudio.google.com/
GEMINI_API_KEY=YOUR_GEMINI_API_KEY

# --- Cloudinary (lưu ảnh upload vĩnh viễn) ---
# Đăng ký miễn phí tại: https://cloudinary.com
# Lấy credentials tại: Dashboard → API Keys
CLOUDINARY_CLOUD_NAME=YOUR_CLOUD_NAME
CLOUDINARY_API_KEY=YOUR_CLOUDINARY_API_KEY
CLOUDINARY_API_SECRET=YOUR_CLOUDINARY_API_SECRET
